// This is your Prisma schema file,
// TikTok-like Social Media Application Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model - stores user profiles and authentication info
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  displayName   String?
  bio           String?
  avatarUrl     String?
  bannerUrl     String?
  passwordHash  String?   // For email/password auth
  googleId      String?   // For Google Sign-In
  isVerified    Boolean   @default(false)
  isPrivate     Boolean   @default(false)
  
  // Stats
  videosCount   Int       @default(0)
  likesCount    Int       @default(0)
  followersCount Int      @default(0)
  followingCount Int      @default(0)
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastActiveAt  DateTime  @default(now())
  
  // Relations
  videos        Video[]
  likes         Like[]
  comments      Comment[]
  followers     Follow[]  @relation("UserFollowers")
  following     Follow[]  @relation("UserFollowing")
  notifications Notification[]
  videoViews    VideoView[]
  
  @@index([email])
  @@index([username])
  @@index([createdAt])
}

// Video model - stores video metadata
model Video {
  id            String    @id @default(cuid())
  authorId      String
  
  // Video content
  videoUrl      String
  thumbnailUrl  String?
  caption       String?
  hashtags      String    // JSON array of hashtags
  
  // Stats
  viewsCount    Int       @default(0)
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  sharesCount   Int       @default(0)
  
  // Video metadata
  duration      Int?      // Duration in seconds
  width         Int?
  height        Int?
  fileSize      Int?      // File size in bytes
  
  // Status
  status        VideoStatus @default(PROCESSING)
  isFeatured    Boolean   @default(false)
  isReported    Boolean   @default(false)
  
  // Recommendation score
  trendingScore Float     @default(0)
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?
  
  // Relations
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  videoViews    VideoView[]
  
  @@index([authorId])
  @@index([createdAt])
  @@index([trendingScore])
  @@index([status])
}

// Like model - tracks video likes
model Like {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  
  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

// Comment model - video comments
model Comment {
  id        String   @id @default(cuid())
  videoId   String
  userId    String
  parentId  String?  // For replies
  content   String
  likesCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  
  @@index([videoId])
  @@index([userId])
  @@index([createdAt])
}

// Follow model - user relationships
model Follow {
  followerId   String
  followingId  String
  createdAt    DateTime @default(now())
  
  follower     User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  
  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// Notification model - user notifications
model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  content     String?
  data        String?          // JSON for additional data
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
}

// VideoView model - tracks watch history for recommendations
model VideoView {
  id          String   @id @default(cuid())
  userId      String
  videoId     String
  watchTime   Int      @default(0)  // Watch time in seconds
  percentage  Float    @default(0)  // Percentage of video watched
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  
  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

// Hashtag model for trending tags
model Hashtag {
  id          String   @id @default(cuid())
  name        String   @unique
  videosCount Int      @default(0)
  createdAt   DateTime @default(now())
  
  @@index([name])
  @@index([videosCount])
}

// Enums
enum VideoStatus {
  PROCESSING
  PUBLISHED
  ARCHIVED
  DELETED
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  MENTION
  SYSTEM
}
